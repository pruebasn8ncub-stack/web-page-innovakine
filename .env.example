# ===========================================
# InnovaKine - Variables de Entorno
# Copia este archivo como .env.local y completa los valores
# ===========================================

# Supabase (self-hosted en Hostinger/EasyPanel)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# N8N Webhook (chatbot Kini)
N8N_WEBHOOK_URL=

# Backend API (agenda)
NEXT_PUBLIC_API_URL=

# Supabase Service Role Key (solo server-side, NUNCA exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=

# Supabase DB (conexión directa PostgreSQL)
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_USER=
SUPABASE_DB_PASSWORD=
SUPABASE_JWT_SECRET=

# N8N API
N8N_API_URL=
N8N_API_KEY=

# Evolution API (WhatsApp)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=

# WhatsApp Bot
WHATSAPP_TESTING_NUMBERS=
N8N_WHATSAPP_WEBHOOK_URL=
WHATSAPP_WEBHOOK_SECRET=

# Chatwoot
CHATWOOT_URL=
